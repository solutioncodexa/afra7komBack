# Exemple env.prod à placer dans ~/afra7kom/env.prod sur le VPS
# Ne pas committer les secrets réels.

SPRING_PROFILES_ACTIVE=prod

# MinIO (obligatoire en prod)
MINIO_ENABLED=true
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_ACCESS
MINIO_SECRET_KEY=CHANGE_ME_SECRET
MINIO_BUCKET=afra7kom
MINIO_PUBLIC_URL=https://api.afra7kom.ma
MINIO_FALLBACK_LOCAL=false

# DB / JWT / etc. (compléter selon votre env)
# SPRING_DATASOURCE_URL=jdbc:postgresql://...
# JWT_SECRET=...
