    <changeSet id="002f-reset-sequences" author="afra7kom">
        <!-- Reset sequences to avoid ID conflicts -->
        <sql>
            SELECT setval('users_id_seq', (SELECT MAX(id) FROM users));
        </sql>
        <sql>
            SELECT setval('roles_id_seq', (SELECT MAX(id) FROM roles));
