    <changeSet id="002c-assign-role-permissions" author="afra7kom">
        <!-- ADMIN: All permissions -->
        <sql>
            INSERT INTO role_permissions (role_id, permission_id)
            SELECT 1, p.id FROM permissions p;
        </sql>

        <!-- MANAGER: Most permissions except user management -->
        <sql>
            INSERT INTO role_permissions (role_id, permission_id)
            SELECT 2, p.id FROM permissions p 
            WHERE p.name NOT IN ('user:delete', 'user:manage_roles');
        </sql>

        <!-- AGENT: Basic operational permissions -->
        <sql>
            INSERT INTO role_permissions (role_id, permission_id)
            SELECT 3, p.id FROM permissions p 
            WHERE p.name IN (
                'pack:read', 'material:read', 'material:update',
                'reservation:read', 'reservation:create', 'reservation:update', 'reservation:approve'
            );
        </sql>

        <!-- CLIENT: Basic read permissions -->
        <sql>
            INSERT INTO role_permissions (role_id, permission_id)
            SELECT 4, p.id FROM permissions p 
            WHERE p.name IN ('pack:read', 'material:read', 'reservation:create');
        </sql>
    </changeSet>

