        <addForeignKeyConstraint baseTableName="packs" baseColumnNames="categorie_id"
                                constraintName="fk_packs_categorie"
                                referencedTableName="categories" referencedColumnNames="id"
                                onDelete="RESTRICT"/>
        
        <createIndex tableName="packs" indexName="idx_packs_active">
            <column name="active"/>
        </createIndex>
    </changeSet>

    <changeSet id="004-create-pack-materiels-table" author="afra7kom">
        <createTable tableName="pack_materiels">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="pack_id" type="BIGINT">
