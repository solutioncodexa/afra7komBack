        <insert tableName="pack_images">
            <column name="pack_id" valueNumeric="1"/>
            <column name="gallery_id" valueNumeric="2"/>
            <column name="sort_order" valueNumeric="1"/>
            <column name="created_at" valueDate="2025-01-01T00:00:00"/>
        </insert>
        <insert tableName="pack_images">
            <column name="pack_id" valueNumeric="1"/>
            <column name="gallery_id" valueNumeric="3"/>
            <column name="sort_order" valueNumeric="2"/>
            <column name="created_at" valueDate="2025-01-01T00:00:00"/>
        </insert>

        <!-- Pack Naissance (ID 2) avec images 4, 5, 6 -->
