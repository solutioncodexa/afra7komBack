<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

    <changeSet id="010-fix-materiels-sequence-final" author="afra7kom">
        <!-- Fix the sequence for materiels table to start after the maximum existing ID -->
        <sql>
            -- Reset the sequence to start from the next available ID
            SELECT setval('materiels_id_seq', COALESCE((SELECT MAX(id) FROM materiels), 0) + 1, false);
        </sql>
    </changeSet>

</databaseChangeLog>


