<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

    <changeSet id="007-create-gallery-table" author="afra7kom">
        <!-- Create gallery table -->
        <createTable tableName="gallery">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(500)"/>
            <column name="image_url" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="alt_text" type="VARCHAR(100)"/>
            <column name="category" type="VARCHAR(50)"/>
            <column name="sort_order" type="INTEGER" defaultValueNumeric="0"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="featured" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="created_by" type="BIGINT">
                <constraints foreignKeyName="fk_gallery_user" references="users(id)"/>
            </column>
        </createTable>

        <!-- Create index on category for better performance -->
        <createIndex tableName="gallery" indexName="idx_gallery_category">
            <column name="category"/>
        </createIndex>

        <!-- Create index on active status -->
        <createIndex tableName="gallery" indexName="idx_gallery_active">
            <column name="active"/>
        </createIndex>

        <!-- Create index on featured status -->
        <createIndex tableName="gallery" indexName="idx_gallery_featured">
            <column name="featured"/>
        </createIndex>

        <!-- Create index on sort order -->
        <createIndex tableName="gallery" indexName="idx_gallery_sort_order">
            <column name="sort_order"/>
        </createIndex>
    </changeSet>

