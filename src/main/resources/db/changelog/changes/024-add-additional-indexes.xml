<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="024-add-additional-indexes" author="system">
        <comment>Ajout d'index supplémentaires pour optimiser les performances (tri, audit)</comment>

        <!-- Index pour le tri par date de création - Packs -->
        <createIndex tableName="packs" indexName="idx_packs_created_at">
            <column name="created_at" descending="true"/>
        </createIndex>

        <!-- Index pour le tri par date de création - Matériels -->
        <createIndex tableName="materiels" indexName="idx_materiels_created_at">
            <column name="created_at" descending="true"/>
        </createIndex>


        <!-- Index pour les audit logs par utilisateur -->
        <createIndex tableName="audit_logs" indexName="idx_audit_logs_user_id">
            <column name="user_id"/>
        </createIndex>

        <!-- ANALYZE pour mettre à jour les statistiques PostgreSQL -->
        <sql>
            ANALYZE packs;
            ANALYZE materiels;
            ANALYZE reservations;
            ANALYZE pack_materiels;
            ANALYZE audit_logs;
        </sql>

    </changeSet>

</databaseChangeLog>


